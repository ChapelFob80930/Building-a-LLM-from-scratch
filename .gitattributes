# Auto detect text files and perform LF normalization
* text=auto
*.pth filter=lfs diff=lfs merge=lfs -text
*.json filter=lfs diff=lfs merge=lfs -text
*.bpe filter=lfs diff=lfs merge=lfs -text
*.model filter=lfs diff=lfs merge=lfs -text
*.vocab filter=lfs diff=lfs merge=lfs -text
/building_the_GPT_tokenizer/TinyStoriesV2-GPT4-train.txt filter=lfs diff=lfs merge=lfs -text
/building_the_GPT_tokenizer/bpe_tokenizer.model filter=lfs diff=lfs merge=lfs -text
/building_the_GPT_tokenizer/bpe_tokenizer.vocab filter=lfs diff=lfs merge=lfs -text
